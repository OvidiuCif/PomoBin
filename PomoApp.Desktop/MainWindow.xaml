<Window x:Class="PomoApp.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PomoBin 🍅" 
        Height="480" Width="680" 
        MinHeight="480" MinWidth="680"
        ResizeMode="CanResizeWithGrip" WindowStartupLocation="CenterScreen"
        Background="#AF4949"
        FontFamily="Segoe UI">

    <Window.Resources>
        <SolidColorBrush x:Key="WindowBrush" Color="#AF4949"/>
        <Style TargetType="Button" x:Key="PrimaryActionBtn">
            <Setter Property="Foreground" Value="#AF4949"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="22">
                            <Border.Effect>
                                <DropShadowEffect Color="Black" Opacity="0.15" BlurRadius="10" ShadowDepth="3"/>
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#F1F2F6"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#E1E2E6"/>
                                <Setter TargetName="Border" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect Color="Black" Opacity="0.05" BlurRadius="4" ShadowDepth="1"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Button" x:Key="SecondaryActionBtn">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#33FFFFFF"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Border" Background="{TemplateBinding Background}" CornerRadius="18">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#4DFFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#1AFFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Ellipse Fill="#1AFFFFFF" Width="350" Height="350" Margin="-100,-150,0,0" HorizontalAlignment="Left" VerticalAlignment="Top"/>
        <Ellipse Fill="#0DFFFFFF" Width="250" Height="250" Margin="0,0,-50,-80" HorizontalAlignment="Right" VerticalAlignment="Bottom"/>

        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="20">

            <Border Background="#33000000" CornerRadius="12" HorizontalAlignment="Center" Padding="16,6" Margin="0,0,0,20">
                <TextBlock x:Name="PhaseLabel" 
                           Text="WORK FOCUS" 
                           FontSize="12" FontWeight="Bold" 
                           Foreground="White"/>
            </Border>

            <TextBlock x:Name="TimerDisplay"
                       Text="25:00"
                       FontFamily="Arial Rounded MT Bold, Segoe UI"
                       FontSize="96" FontWeight="Bold"
                       HorizontalAlignment="Center"
                       Foreground="White"
                       Margin="0,0,0,30">
                <TextBlock.Effect>
                    <DropShadowEffect Color="Black" Opacity="0.2" BlurRadius="10" ShadowDepth="4"/>
                </TextBlock.Effect>
            </TextBlock>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,40">
                <Button Content="Reset" Style="{StaticResource SecondaryActionBtn}" 
                        Width="80" Height="36" Margin="0,0,20,0" Click="Reset_Click"/>

                <Button x:Name="StartPauseButton" Content="START" Style="{StaticResource PrimaryActionBtn}" 
                        Width="120" Height="48" Click="StartPause_Click"/>

                <Button Content="Skip →" Style="{StaticResource SecondaryActionBtn}" 
                        Width="80" Height="36" Margin="20,0,0,0" Click="Skip_Click"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <TextBlock Text="🍅" Foreground="White" FontSize="16" Margin="0,0,8,0" VerticalAlignment="Center"/>
                <TextBlock x:Name="SessionLabel"
                           Text="Sessions completed: 0"
                           FontSize="14"
                           Foreground="#FFD1D1"
                           VerticalAlignment="Center"/>
            </StackPanel>

        </StackPanel>
    </Grid>
</Window>