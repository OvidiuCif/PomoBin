<Window x:Class="PomoApp.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="PomoBin 🍅" Height="350" Width="550"
        ResizeMode="CanResizeWithGrip" WindowStartupLocation="CenterScreen"
        Background="#AF4949">

    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Foreground"       Value="White"/>
            <Setter Property="FontWeight"       Value="SemiBold"/>
            <Setter Property="Cursor"           Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Border"
                                Background="#8A3535"
                                BorderBrush="#6B2525"
                                BorderThickness="1"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#9C3D3D"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#6B2525"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <StackPanel Margin="30" VerticalAlignment="Center">

        <TextBlock x:Name="PhaseLabel"
                   Text="Work PomoBin"
                   FontSize="18" FontWeight="SemiBold"
                   HorizontalAlignment="Center"
                   Foreground="White"
                   Margin="0,0,0,6"/>

        <TextBlock x:Name="TimerDisplay"
                   Text="25:00"
                   FontSize="64" FontWeight="Bold"
                   HorizontalAlignment="Center"
                   Foreground="White"
                   Margin="0,0,0,24"/>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
            <Button x:Name="StartPauseButton" Content="Start"
                    Width="90" Height="36" Margin="6,0"
                    Click="StartPause_Click"/>
            <Button Content="Reset"
                    Width="90" Height="36" Margin="6,0"
                    Click="Reset_Click"/>
            <Button Content="Skip →"
                    Width="90" Height="36" Margin="6,0"
                    Click="Skip_Click"/>
        </StackPanel>

        <TextBlock x:Name="SessionLabel"
                   Text="Sessions completed: 0"
                   HorizontalAlignment="Center"
                   Foreground="#FADBD8"
                   Margin="0,20,0,0"/>

    </StackPanel>
</Window>
