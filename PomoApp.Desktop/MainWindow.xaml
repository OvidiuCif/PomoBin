<Window x:Class="PomoApp.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="PomoApp" Height="320" Width="400"
        ResizeMode="NoResize" WindowStartupLocation="CenterScreen">
    <StackPanel Margin="30" VerticalAlignment="Center">

        <TextBlock x:Name="PhaseLabel"
                   Text="Work"
                   FontSize="18" FontWeight="SemiBold"
                   HorizontalAlignment="Center"
                   Foreground="Crimson"
                   Margin="0,0,0,6"/>

        <TextBlock x:Name="TimerDisplay"
                   Text="25:00"
                   FontSize="64" FontWeight="Bold"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,24"/>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
            <Button x:Name="StartPauseButton" Content="Start"
                    Width="90" Height="36" Margin="6,0"
                    Click="StartPause_Click"/>
            <Button Content="Reset"
                    Width="90" Height="36" Margin="6,0"
                    Click="Reset_Click"/>
            <Button Content="Skip →"
                    Width="90" Height="36" Margin="6,0"
                    Click="Skip_Click"/>
        </StackPanel>

        <TextBlock x:Name="SessionLabel"
                   Text="Sessions completed: 0"
                   HorizontalAlignment="Center"
                   Foreground="Gray"
                   Margin="0,20,0,0"/>

    </StackPanel>
</Window>
